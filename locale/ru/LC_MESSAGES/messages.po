msgid "This field is required."
msgstr "Это поле обязательно к заполнению."

msgid "This is not a valid email."
msgstr "Это недействительный адрес электронной почты."

msgid "This is optional. You can also use a per-document password instead."
msgstr ""
"Это необязательно. Вместо этого вы также можете использовать пароль для "
"каждого документа."

