msgstr "Tipo"

msgid "Type @ in the editor to insert a citation or cross-reference:"
msgstr "Escriba @ en el editor para insertar una cita o referencia cruzada:"

msgid ""
"Type $ in the editor followed by LaTeX math to insert an equation inline, "
"e.g. $x^2. Press Enter or Tab to confirm."
msgstr ""
"Escriba $ en el editor seguido de matemáticas LaTeX para insertar una "
"ecuación en línea, p. $x^2. Presione Enter o Tab para confirmar."

msgid "Undefined"
msgstr "Indefinido"

