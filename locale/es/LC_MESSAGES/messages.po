msgstr "Actualizar"

msgid "Updating document templates."
msgstr "Actualizando plantillas de documentos"

msgid "Updating documents."
msgstr "Actualización de documentos."

msgid "Updating saved revisions."
msgstr "Actualizando las versiones guardadas"

msgid "Updating..."
msgstr "Actualizando..."

msgid "Upload"
msgstr "Subir"

msgid "Upload FIDUSTEMPLATE file"
msgstr "Subir archivo FIDUSTEMPLATE"

msgid "Upload your profile picture"
msgstr "Subir imagen de perfil"

msgid "User"
msgstr "Usuario"

